{
  "name": "codebase-index",
  "version": "1.0.0",
  "description": "AST-aware codebase indexing with semantic search, exposed as an MCP server",
  "type": "module",
  "bin": {
    "codebase-index": "./bin/cli.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "codebase",
    "vector",
    "search",
    "embeddings",
    "ollama",
    "tree-sitter",
    "semantic-search"
  ],
  "license": "MIT",
  "dependencies": {
    "@lancedb/lancedb": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "apache-arrow": "^18.0.0",
    "commander": "^13.0.0",
    "fast-glob": "^3.3.0",
    "p-limit": "^6.0.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.23.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18"
  }
}
